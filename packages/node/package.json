{
    "name": "@repo/node",
    "private": true,
    "type": "module",
    "exports": {
        "./*": {
            "types": "./src/*.ts",
            "default": "./build/src/*.js"
        }
    },
    "scripts": {
        "dev": "tsc -b --watch",
        "build": "tsc -b",
        "debug": "tsc --showConfig",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:update": "vitest run --update"
    },
    "dependencies": {
        "@repo/shared": "*",
        "@types/node": "^25.2.1",
        "tar-stream": "^3.1.8"
    },
    "devDependencies": {
        "@types/tar-stream": "^3.1.4"
    }
}
